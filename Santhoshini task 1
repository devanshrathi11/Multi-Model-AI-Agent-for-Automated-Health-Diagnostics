def calculate_accuracy(predicted, actual):
    correct = 0
    for param in actual:
        if param in predicted and predicted[param] == actual[param]:
            correct += 1
    return (correct / len(actual)) * 100

# Example usage
actual_labels = {
    "Hemoglobin": "Normal",
    "WBC": "High"
}

predicted_labels = {
    "Hemoglobin": "Normal",
    "WBC": "High"
}

accuracy = calculate_accuracy(predicted_labels, actual_labels)
print("Classification Accuracy:", accuracy, "%")
